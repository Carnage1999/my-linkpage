{
  "compilerOptions": {
    "target": "ES2025",
    "lib": ["ES2025", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": [
    "src",
    "scripts",
    "vite.config.ts",
    "tailwind.config.ts",
    "eslint.config.ts",
    "postcss.config.ts",
    "prettier.config.ts",
    "playwright.config.ts",
    "eslint-plugin-tailwindcss.d.ts"
  ]
}
